{
   "action": {
      "default_icon": {
         "128": "/images/icon2.png",
         "16": "/images/icon2.png",
         "32": "/images/icon2.png",
         "48": "/images/icon2.png"
      },
      "default_popup": "popup.html",
      "default_title": "点击打开"
   },
   "author": "lwh",
   "background": {
      "service_worker": "background.js"
   },
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "content_scripts": [ {
      "all_frames": true,
      "css": [ "/css/baidu.css" ],
      "js": ["/js/baidu.js"],
      "matches": [ "https://*.baidu.com/*" ],
      "run_at": "document_end"
   }],
   "description": "lwh test",
   "host_permissions": ["http://www.xxxx.com/*"],
   "icons": {
      "128": "/images/icon.png",
      "16": "/images/icon.png",
      "32": "/images/icon.png",
      "48": "/images/icon.png"
   },
   "manifest_version": 3,
   "name": "入门1",
   "permissions": [ "background", "storage","sidePanel", "tabs", "activeTab", "scripting"],
   "version": "1.0"
}