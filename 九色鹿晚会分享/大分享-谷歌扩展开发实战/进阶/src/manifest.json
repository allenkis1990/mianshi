{
   "action": {
      "default_icon": {
         "128": "/images/icon.png",
         "16": "/images/icon.png",
         "32": "/images/icon.png",
         "48": "/images/icon.png"
      }
   },
   "author": "lwh",
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "css": [ "/css/baidu.css" ],
      "js": ["/js/contentScripts/baidu.js"],
      "matches": [ "https://*.baidu.com/*" ],
      "run_at": "document_end"
   }],
   "description": "lwh test",
   "host_permissions": ["https://pre-api.thedeer.cn/*"],
   "icons": {
      "128": "/images/icon.png",
      "16": "/images/icon.png",
      "32": "/images/icon.png",
      "48": "/images/icon.png"
   },
   "manifest_version": 3,
   "name": "换肤插件",
   "permissions": [ "background", "storage","sidePanel", "tabs", "activeTab", "scripting"],
   "version": "1.0"
}